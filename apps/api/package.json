{
  "name": "@dtracker/api",
  "version": "0.0.1",
  "private": true,
  "description": "A NestJS API for the DTracker application",
  "license": "UNLICENSED",
  "author": "Jovan Veljanoski",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:e2e": "vitest run --config ./vitest.config.e2e.ts",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check",
    "db:pull": "drizzle-kit pull",
    "db:seed": "tsx src/core/database/seed.ts",
    "auth:generate": "pnpm dlx auth generate --config=./src/auth/auth.config.ts"
  },
  "dependencies": {
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@thallesp/nestjs-better-auth": "^2.6.1",
    "better-auth": "catalog:",
    "dotenv": "^17.4.0",
    "dotenv-expand": "^12.0.3",
    "drizzle-orm": "^1.0.0-beta.22",
    "drizzle-seed": "^1.0.0-beta.22",
    "helmet": "^8.1.0",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.2.1",
    "nodemailer": "^9.0.1",
    "pg": "^8.20.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.18",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.24",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.17",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "^4.1.2",
    "drizzle-kit": "^1.0.0-beta.22",
    "globals": "^16.5.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "vitest": "^4.1.2"
  }
}
