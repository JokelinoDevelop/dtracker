{
  "name": "dtracker",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install",
    "db:generate": "turbo -F @dtracker/api db:generate",
    "db:push": "pnpm --filter @dtracker/api db:push",
    "db:migrate": "pnpm --filter @dtracker/api db:migrate",
    "db:studio": "pnpm --filter @dtracker/api db:studio",
    "db:check": "pnpm --filter @dtracker/api db:check",
    "db:pull": "pnpm --filter @dtracker/api db:pull",
    "db:seed": "pnpm --filter @dtracker/api db:seed"
  },
  "devDependencies": {
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "@typescript/native-preview": "7.0.0-dev.20260609.1",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "turbo": "^2.9.16",
    "ultracite": "7.8.2"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.6.0"
}
