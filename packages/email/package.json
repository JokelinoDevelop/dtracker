{
  "name": "@dtracker/email",
  "version": "1.0.0",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "check-types": "tsgo --noEmit",
    "email:dev": "email dev --port=3001"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "dotenv-expand": "^12.0.3",
    "nodemailer": "^9.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-email": "6.6.4"
  },
  "devDependencies": {
    "@dtracker/config": "workspace:*",
    "@react-email/ui": "6.6.4",
    "@types/node": "^26.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript/native-preview": "catalog:",
    "tsdown": "^0.22.3"
  }
}
